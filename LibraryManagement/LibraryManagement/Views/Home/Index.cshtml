@{
    ViewData["Title"] = "Home";
}

<div class="px-4 py-5 my-3 text-center">
    <i class="bi bi-book-half display-1 text-dark"></i>
    <h1 class="display-5 fw-bold mt-3">School Library System</h1>
    <p class="col-lg-6 mx-auto lead text-muted">
        Manage books, authors, and borrowing records all in one place.
    </p>
    <div class="d-grid gap-2 d-sm-flex justify-content-sm-center mt-4">
        <a asp-controller="Books" asp-action="Index" class="btn btn-dark btn-lg px-4">
            <i class="bi bi-journals me-2"></i>Browse Books
        </a>
        <a asp-controller="Books" asp-action="Create" class="btn btn-outline-secondary btn-lg px-4">
            <i class="bi bi-plus-circle me-2"></i>Add New Book
        </a>
    </div>
</div>

<hr />

<!-- Stats cards -->
<div class="row g-4 mt-2">
    <div class="col-md-4">
        <div class="card text-center shadow-sm border-0 h-100">
            <div class="card-body py-4">
                <i class="bi bi-journals fs-1 text-primary mb-2"></i>
                <h2 class="fw-bold">@ViewBag.TotalBooks</h2>
                <p class="text-muted mb-0">Total Books</p>
            </div>
            <div class="card-footer bg-transparent border-0 pb-3">
                <a asp-controller="Books" asp-action="Index" class="btn btn-sm btn-outline-primary">
                    View All
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center shadow-sm border-0 h-100">
            <div class="card-body py-4">
                <i class="bi bi-people fs-1 text-success mb-2"></i>
                <h2 class="fw-bold">@ViewBag.TotalAuthors</h2>
                <p class="text-muted mb-0">Registered Authors</p>
            </div>
            <div class="card-footer bg-transparent border-0 pb-3">
                <a asp-controller="Authors" asp-action="Index" class="btn btn-sm btn-outline-success">
                    View All
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center shadow-sm border-0 h-100">
            <div class="card-body py-4">
                <i class="bi bi-clock-history fs-1 text-warning mb-2"></i>
                <h2 class="fw-bold">@ViewBag.TotalBorrowed</h2>
                <p class="text-muted mb-0">Currently Borrowed</p>
            </div>
            <div class="card-footer bg-transparent border-0 pb-3">
                <a asp-controller="Books" asp-action="Index" class="btn btn-sm btn-outline-warning">
                    View Books
                </a>
            </div>
        </div>
    </div>
</div>
