@model LibraryManagement.Models.ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-5">
    <i class="bi bi-exclamation-triangle-fill display-1 text-danger"></i>
    <h1 class="mt-3">Something went wrong.</h1>
    <p class="text-muted">An error occurred while processing your request.</p>
    @if (Model.ShowRequestId)
    {
        <p>
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }
    <a asp-controller="Home" asp-action="Index" class="btn btn-dark mt-3">
        <i class="bi bi-house me-1"></i>Back to Home
    </a>
</div>
