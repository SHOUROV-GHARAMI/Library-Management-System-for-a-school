@model IEnumerable<LibraryManagement.ViewModels.BookIndexViewModel>
@{
    ViewData["Title"] = "Books";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0"><i class="bi bi-journals me-2"></i>All Books</h2>
        <small class="text-muted">@Model.Count() book(s) found — sorted by title</small>
    </div>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle me-1"></i>Add Book
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center py-5">
        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
        No books in the library yet.
        <a asp-action="Create" class="alert-link">Add the first one!</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Title</th>
                    <th>ISBN</th>
                    <th>Author</th>
                    <th class="text-center">Availability</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @{int row = 1;}
                @foreach (var book in Model)
                {
                    <tr>
                        <td class="text-muted">@row</td>
                        <td><strong>@book.Title</strong></td>
                        <td><code>@book.ISBN</code></td>
                        <td>@book.AuthorFullName</td>
                        <td class="text-center">
                            @if (book.AvailableCopies == 0)
                            {
                                <span class="badge bg-danger fs-6">
                                    @book.AvailableCopies / @book.TotalCopies
                                </span>
                            }
                            else if (book.AvailableCopies < book.TotalCopies)
                            {
                                <span class="badge bg-warning text-dark fs-6">
                                    @book.AvailableCopies / @book.TotalCopies
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success fs-6">
                                    @book.AvailableCopies / @book.TotalCopies
                                </span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@book.Id"
                               class="btn btn-sm btn-outline-info me-1">
                                <i class="bi bi-eye"></i> Details
                            </a>
                            <a asp-action="Edit" asp-route-id="@book.Id"
                               class="btn btn-sm btn-outline-secondary me-1">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <a asp-action="Borrow" asp-route-bookId="@book.Id"
                               class="btn btn-sm btn-outline-warning
                                      @(book.AvailableCopies == 0 ? "disabled" : "")">
                                <i class="bi bi-arrow-bar-up"></i> Borrow
                            </a>
                        </td>
                    </tr>
                    row++;
                }
            </tbody>
        </table>
    </div>
}
