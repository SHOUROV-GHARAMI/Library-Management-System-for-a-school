@model LibraryManagement.Models.Book
@{
    ViewData["Title"] = Model.Title;
}

<!-- Book header -->
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h2 class="mb-1"><i class="bi bi-book me-2"></i>@Model.Title</h2>
        <small class="text-muted">Book Details</small>
    </div>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id"
           class="btn btn-outline-primary me-1">
            <i class="bi bi-pencil me-1"></i>Edit
        </a>
        <a asp-action="Borrow" asp-route-bookId="@Model.Id"
           class="btn btn-warning me-1
                  @(Model.AvailableCopies == 0 ? "disabled" : "")">
            <i class="bi bi-arrow-bar-up me-1"></i>Borrow
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<hr />

<!-- Book info card -->
<div class="row g-4 mb-5">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white">
                <i class="bi bi-info-circle me-1"></i> Book Information
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Title</dt>
                    <dd class="col-sm-8">@Model.Title</dd>

                    <dt class="col-sm-4">ISBN</dt>
                    <dd class="col-sm-8"><code>@Model.ISBN</code></dd>

                    <dt class="col-sm-4">Author</dt>
                    <dd class="col-sm-8">
                        <a asp-controller="Authors" asp-action="Details"
                           asp-route-id="@Model.AuthorId">
                            @Model.Author?.FullName
                        </a>
                    </dd>

                    <dt class="col-sm-4">Published</dt>
                    <dd class="col-sm-8">@Model.PublicationYear</dd>

                    <dt class="col-sm-4">Total Copies</dt>
                    <dd class="col-sm-8">@Model.TotalCopies</dd>

                    <dt class="col-sm-4">Available</dt>
                    <dd class="col-sm-8">
                        @if (Model.AvailableCopies == 0)
                        {
                            <span class="badge bg-danger">@Model.AvailableCopies — None available</span>
                        }
                        else
                        {
                            <span class="badge bg-success">@Model.AvailableCopies available</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<!-- Borrow Records table -->
<h4><i class="bi bi-clock-history me-2"></i>Borrow Records</h4>
<hr />

@if (!Model.BorrowRecords.Any())
{
    <div class="alert alert-secondary text-center py-4">
        <i class="bi bi-inbox d-block fs-2 mb-1"></i>
        No borrow records for this book yet.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-bordered table-hover table-sm align-middle">
            <thead class="table-secondary">
                <tr>
                    <th>Student Name</th>
                    <th>Borrow Date</th>
                    <th>Due Date</th>
                    <th>Return Date</th>
                    <th class="text-center">Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.BorrowRecords.OrderByDescending(r => r.BorrowDate))
                {
                    <tr>
                        <td>@r.StudentName</td>
                        <td>@r.BorrowDate.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@r.DueDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            @(r.ReturnDate.HasValue
                                ? r.ReturnDate.Value.ToString("yyyy-MM-dd")
                                : "Not returned")
                        </td>
                        <td class="text-center">
                            @if (r.IsReturned)
                            {
                                <span class="badge bg-success">Returned</span>
                            }
                            else if (r.DueDate < DateTime.Today)
                            {
                                <span class="badge bg-danger">Overdue</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Active</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
