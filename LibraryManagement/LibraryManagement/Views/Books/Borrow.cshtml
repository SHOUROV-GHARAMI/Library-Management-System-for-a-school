@model LibraryManagement.ViewModels.BorrowViewModel
@{
    ViewData["Title"] = "Borrow Book";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0"><i class="bi bi-arrow-bar-up me-2"></i>Borrow Book</h2>
        <small class="text-muted">Complete the form to borrow this book</small>
    </div>
    <a asp-controller="Books" asp-action="Details" asp-route-id="@Model.BookId"
       class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
</div>

<hr />

<div class="row">
    <div class="col-lg-6">

        <!-- Book info banner -->
        <div class="alert alert-dark d-flex align-items-center mb-4" role="alert">
            <i class="bi bi-book fs-4 me-3"></i>
            <div>
                <strong>@Model.BookTitle</strong>
                <div class="small text-white-50">You are borrowing this book</div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-warning text-dark fw-semibold">
                <i class="bi bi-person-check me-1"></i> Borrower Details
            </div>
            <div class="card-body p-4">

                <form asp-action="Borrow" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="BookId" />
                    <input type="hidden" asp-for="BookTitle" />

                    <!-- Model-level errors (e.g. "No copies available") -->
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            @foreach (var error in ViewData.ModelState
                                          .Where(x => x.Key == string.Empty)
                                          .SelectMany(x => x.Value!.Errors))
                            {
                                <div>@error.ErrorMessage</div>
                            }
                        </div>
                    }

                    <!-- Student Name -->
                    <div class="mb-3">
                        <label asp-for="StudentName" class="form-label fw-semibold"></label>
                        <input asp-for="StudentName" class="form-control"
                               placeholder="Full name of the student" maxlength="100" />
                        <span asp-validation-for="StudentName" class="text-danger small"></span>
                    </div>

                    <!-- Due Date -->
                    <div class="mb-4">
                        <label asp-for="DueDate" class="form-label fw-semibold"></label>
                        <input asp-for="DueDate" class="form-control" type="date"
                               min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        <div class="form-text">Default is 14 days from today.</div>
                        <span asp-validation-for="DueDate" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning px-4 fw-semibold">
                            <i class="bi bi-check-circle me-1"></i>Confirm Borrow
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.BookId"
                           class="btn btn-outline-secondary px-4">
                            Cancel
                        </a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
