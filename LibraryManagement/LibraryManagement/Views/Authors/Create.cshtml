@model LibraryManagement.Models.Author
@{
    ViewData["Title"] = "Add Author";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0"><i class="bi bi-person-plus me-2"></i>Add New Author</h2>
        <small class="text-muted">Fill in the details below</small>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to List
    </a>
</div>

<hr />

<div class="row">
    <div class="col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white">
                <i class="bi bi-person me-1"></i> Author Details
            </div>
            <div class="card-body p-4">

                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger mb-3"></div>

                    <!-- First Name -->
                    <div class="mb-3">
                        <label asp-for="FirstName" class="form-label fw-semibold"></label>
                        <input asp-for="FirstName" class="form-control"
                               placeholder="e.g. George" />
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>

                    <!-- Last Name -->
                    <div class="mb-3">
                        <label asp-for="LastName" class="form-label fw-semibold"></label>
                        <input asp-for="LastName" class="form-control"
                               placeholder="e.g. Orwell" />
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>

                    <!-- Date of Birth -->
                    <div class="mb-4">
                        <label asp-for="DateOfBirth" class="form-label fw-semibold"></label>
                        <input asp-for="DateOfBirth" class="form-control" type="date" />
                        <div class="form-text">Optional</div>
                        <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success px-4">
                            <i class="bi bi-check-circle me-1"></i>Save Author
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">
                            Cancel
                        </a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
