@model LibraryManagement.Models.Author
@{
    ViewData["Title"] = Model.FullName;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0"><i class="bi bi-person me-2"></i>@Model.FullName</h2>
        <small class="text-muted">Author Details</small>
    </div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary me-1">
        <i class="bi bi-pencil me-1"></i>Edit
    </a>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
</div>

<hr />

<div class="row g-4">
    <div class="col-md-5">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white">
                <i class="bi bi-person-badge me-1"></i> Author Info
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">First Name</dt>
                    <dd class="col-sm-7">@Model.FirstName</dd>

                    <dt class="col-sm-5">Last Name</dt>
                    <dd class="col-sm-7">@Model.LastName</dd>

                    <dt class="col-sm-5">Date of Birth</dt>
                    <dd class="col-sm-7">
                        @(Model.DateOfBirth.HasValue
                            ? Model.DateOfBirth.Value.ToString("MMMM dd, yyyy")
                            : "Not provided")
                    </dd>

                    <dt class="col-sm-5">Total Books</dt>
                    <dd class="col-sm-7">
                        <span class="badge bg-primary">@Model.Books.Count</span>
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <h5><i class="bi bi-journals me-2"></i>Books by @Model.FullName</h5>
        @if (!Model.Books.Any())
        {
            <p class="text-muted">No books registered for this author.</p>
        }
        else
        {
            <ul class="list-group shadow-sm">
                @foreach (var book in Model.Books.OrderBy(b => b.Title))
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <div>
                            <strong>@book.Title</strong>
                            <small class="text-muted ms-2">(@book.PublicationYear)</small>
                        </div>
                        <a asp-controller="Books" asp-action="Details"
                           asp-route-id="@book.Id"
                           class="btn btn-sm btn-outline-info">
                            <i class="bi bi-eye"></i>
                        </a>
                    </li>
                }
            </ul>
        }
    </div>
</div>
